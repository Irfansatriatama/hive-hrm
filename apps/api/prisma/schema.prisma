generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === AUTH (Better Auth tables) ===
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String    @default("EMPLOYEE")
  status        String    @default("active")
  lastLoginAt   DateTime?
  employee      Employee?
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// === HRM CORE ===
model Department {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  createdAt DateTime   @default(now())
  employees Employee[]
  positions Position[]
}

model Position {
  id           String     @id @default(cuid())
  name         String
  grade        String
  salaryMin    Int
  salaryMax    Int
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
}

model Employee {
  id             String         @id @default(cuid())
  employeeNumber String         @unique
  firstName      String
  lastName       String
  fullName       String
  gender         String
  birthDate      DateTime?
  birthPlace     String?
  religion       String?
  maritalStatus  String?
  bloodType      String?
  nationality    String?
  address        String?
  phone          String?
  photoUrl       String?        // Cloudinary URL
  email          String         @unique
  joinDate       DateTime?
  status         EmployeeStatus @default(ACTIVE)
  positionId     String?
  position       Position?      @relation(fields: [positionId], references: [id])
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id])
  managerId      String?
  manager        Employee?      @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates   Employee[]     @relation("ManagerSubordinates")
  userId         String?        @unique
  user           User?          @relation(fields: [userId], references: [id])
  salary         Int            @default(0)
  basicSalary    Int            @default(0)
  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  assets          Asset[]
  assetRequests   AssetRequest[]
  documents       Document[]
  profileRequests ProfileUpdateRequest[]
  rewardPointsReceived RewardPointTransaction[] @relation("RewardPointRecipient")
  rewardPointsSent     RewardPointTransaction[] @relation("RewardPointSender")
  rewardRedemptions    RewardRedemption[]
  pointBalance         EmployeePointBalance?
  shiftSchedules       EmployeeShiftSchedule[]
  shiftSwapsRequested  ShiftSwap[]             @relation("ShiftSwapRequester")
  shiftSwapsPartner    ShiftSwap[]             @relation("ShiftSwapPartner")
  announcementReads    AnnouncementRead[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

model Attendance {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id])
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  status        String    // hadir, izin, sakit, alpha, dll
  workHours     Float?
  lateMinutes   Int?
  location      String?
  notes         String?
  createdAt     DateTime  @default(now())
}

model LeaveType {
  id           String         @id @default(cuid())
  name         String
  maxDays      Int
  isPaid       Boolean        @default(true)
  requests     LeaveRequest[]
}

model LeaveRequest {
  id           String        @id @default(cuid())
  employeeId   String
  employee     Employee      @relation(fields: [employeeId], references: [id])
  leaveTypeId  String
  leaveType    LeaveType     @relation(fields: [leaveTypeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  totalDays    Int
  reason       String?
  status       ApprovalStatus @default(PENDING)
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime      @default(now())
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Asset {
  id            String         @id @default(cuid())
  assetCode     String         @unique
  name          String
  category      String
  brand         String?
  model         String?
  serialNumber  String?
  condition     String
  status        String
  location      String?
  purchaseDate  DateTime?
  purchasePrice Int?
  currentValue  Int?
  assignedDate  DateTime?
  employeeId    String?
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  imageUrl      String?
  notes         String?
  history       AssetHistory[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AssetCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssetLocation {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetRequest {
  id            String   @id @default(cuid())
  requestCode   String   @unique
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  assetId       String?
  assetName     String
  reason        String
  duration      Int
  status        String   @default("pending")
  dateRequested DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AssetHistory {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetCode    String
  assetName    String
  action       String
  employeeId   String?
  employeeName String
  date         DateTime @default(now())
  condition    String?
  createdAt    DateTime @default(now())
}

model DocumentFolder {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Document {
  id           String    @id @default(cuid())
  name         String
  category     String
  fileUrl      String    // Cloudinary URL
  fileType     String
  fileSize     Int?
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id])
  isPublic     Boolean   @default(true)
  visibility   String    @default("all")
  createdAt    DateTime  @default(now())
  uploadedBy   String?
}

model Announcement {
  id          String             @id @default(cuid())
  title       String
  content     String
  target      String             @default("all")
  isPinned    Boolean            @default(false)
  status      String             @default("published")
  publishDate DateTime           @default(now())
  expireDate  DateTime?
  imageUrl    String?
  createdBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  reads       AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, employeeId])
}

model Shift {
  id         String                  @id @default(cuid())
  name       String
  startTime  String                  // "08:00"
  endTime    String                  // "17:00"
  color      String                  @default("#3B82F6")
  split      Boolean                 @default(false)
  breakTime  Int?                    // menit
  isDefault  Boolean                 @default(false)
  createdAt  DateTime                @default(now())
  schedules  EmployeeShiftSchedule[]
}

model EmployeeShiftSchedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  shiftId    String?
  shift      Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, date])
}

model ShiftSwap {
  id           String   @id @default(cuid())
  requesterId  String
  requester    Employee @relation("ShiftSwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  partnerId    String
  partner      Employee @relation("ShiftSwapPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  shiftDetails String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Visitor {
  id             String    @id @default(cuid())
  visitorName    String
  company        String?
  phone          String?
  purpose        String
  hostEmployeeId String?
  checkIn        DateTime  @default(now())
  checkOut       DateTime?
  photoUrl       String?   // Cloudinary URL
  status         String    @default("in")
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  targetType String?
  targetId   String?
  targetName String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

// === COMPANY PROFILE & BRANCHES ===
model Company {
  id        String   @id @default(cuid())
  name      String
  tagline   String?
  industry  String?
  npwp      String?
  phone     String?
  email     String?
  website   String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id         String   @id @default(cuid())
  name       String
  address    String?
  pic        String?
  staffCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  memberIds   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProfileUpdateRequest {
  id          String         @id @default(cuid())
  employeeId  String
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String         // address, emergency, bank, other
  summary     String
  details     Json           // changed fields
  reason      String
  status      ApprovalStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// === SYSTEM CONFIGURATION ===
model SystemModule {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  icon        String?
  isCore      Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublicHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  type        String   @default("national")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoleDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// === HIRING & RECRUITMENT SETTINGS ===
model HiringPipelineStage {
  id        String   @id @default(cuid())
  name      String
  sequence  Int
  pic       String
  duration  Int      @default(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JobTemplate {
  id            String   @id @default(cuid())
  position      String
  description   String
  qualification String
  benefits      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RecruitmentSource {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationFormField {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  required  Boolean  @default(false)
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// === REWARDS & GAMIFICATION ===
model RewardCatalogItem {
  id          String             @id @default(cuid())
  name        String
  description String
  points      Int
  stock       Int                @default(0)
  category    String
  status      String             @default("active")
  imageUrl    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  redemptions RewardRedemption[]
}

model RewardHashtag {
  id          String   @id @default(cuid())
  tag         String   @unique
  description String
  usageCount  Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RewardPointTransaction {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation("RewardPointRecipient", fields: [employeeId], references: [id])
  senderEmployeeId String?
  senderEmployee   Employee? @relation("RewardPointSender", fields: [senderEmployeeId], references: [id])
  type             String
  points           Int
  hashtag          String?
  message          String?
  balanceAfter     Int?
  counterpartyName String?
  rewardCatalogId  String?
  redemptionId     String?
  createdAt        DateTime @default(now())
}

model RewardRedemption {
  id              String            @id @default(cuid())
  employeeId      String
  employee        Employee          @relation(fields: [employeeId], references: [id])
  rewardCatalogId String
  rewardCatalog   RewardCatalogItem @relation(fields: [rewardCatalogId], references: [id])
  points          Int
  status          String            @default("pending")
  dateProcessed   DateTime?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model EmployeePointBalance {
  employeeId String   @id
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  balance    Int      @default(1000)
  updatedAt  DateTime @updatedAt
}
