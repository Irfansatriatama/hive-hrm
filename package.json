{
  "name": "hive-hrm",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "description": "HIVE HRM Enterprise Portal",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w api\" \"npm run dev -w web\"",
    "build": "npm run build -w api && npm run build -w web",
    "build:api": "npm run build -w api",
    "build:web": "npm run build -w web",
    "dev:api": "npm run start:dev -w api",
    "dev:web": "npm run dev -w web",
    "turbo:dev": "turbo dev",
    "turbo:build": "turbo build",
    "mobile:dev": "cd apps/mobile && flutter run",
    "mobile:build:apk": "cd apps/mobile && flutter build apk --release",
    "mobile:build:aab": "cd apps/mobile && flutter build appbundle --release",
    "mobile:test": "cd apps/mobile && flutter test",
    "mobile:l10n": "cd apps/mobile && flutter gen-l10n",
    "mobile:codegen": "cd apps/mobile && dart run build_runner build --delete-conflicting-outputs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.0.0"
  }
}
